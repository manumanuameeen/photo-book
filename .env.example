# ─── APP CONFIGURATION ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── DATABASE & CACHE (Docker handles these internally) ──────────────────────
# For Docker (Local Dev):
MONGO_URI=mongodb://mongodb:27017/photoBookDB
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_secret
REFRESH_TOKEN_SECRET=your_refresh_secret
ACCESS_TOKEN_MAX_AGE=900000
REFRESH_TOKEN_MAX_AGE=604800000
OTP_EXPIRY_SECONDS=120

# ─── EXTERNAL SERVICES (Configure as needed) ─────────────────────────────────
# Nodemailer
SMTP_USER=your_email
SMTP_PASS=your_app_password

# AWS (S3)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
BUCKET_NAME=photo-book-bucket-2025

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# AI (Optional)
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=google/gemini-flash-1.5:free

# Payment (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable
